{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },
      "resource-route": {
        "ClusterId": "resource-cluster",
        "Match": {
          "Path": "/resources/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/resources" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5038/"
          }
        }
      },
      "resource-cluster": {
        "Destinations": {
          "resource-service": {
            "Address": "http://localhost:5226/"
          }
        }
      }
    }
  }
}
