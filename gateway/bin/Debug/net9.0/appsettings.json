{
  "Jwt": {
    "Key": "THIS_IS_A_SUPER_SECRET_KEY_123456789",
    "Issuer": "auth-service",
    "Audience": "auth-service-users"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/auth"
          }
        ]
      },

      "resource-public-route": {
        "ClusterId": "resource-cluster",
        "Match": {
          "Path": "/resources/public/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/resources"
          }
        ]
      },

      "resource-secure-route": {
        "ClusterId": "resource-cluster",
        "Match": {
          "Path": "/resources/secure/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/resources"
          }
        ]
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5038/"
          }
        }
      },

      "resource-cluster": {
        "Destinations": {
          "resource-service": {
            "Address": "http://localhost:5226/"
          }
        }
      }
    }
  }
}
