{
  "Jwt": {
    "Key": "THIS_IS_A_SUPER_SECRET_KEY_123456789",
    "Issuer": "auth-service",
    "Audience": "auth-service-users"
  },

  "ReverseProxy": {
    "Routes": {

      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },

      "resource1-route": {
        "ClusterId": "resource1-cluster",
        "Match": {
          "Path": "/resources1/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/resources1" }
        ]
      },

      "resource2-route": {
        "ClusterId": "resource2-cluster",
        "Match": {
          "Path": "/resources2/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/resources2" }
        ]
      }
    },

    "Clusters": {

      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5038/"
          }
        }
      },

      "resource1-cluster": {
        "Destinations": {
          "resource1-service": {
            "Address": "http://localhost:5226/"
          }
        }
      },

      "resource2-cluster": {
        "Destinations": {
          "resource2-service": {
            "Address": "http://localhost:5295/"
          }
        }
      }
    }
  }
}
