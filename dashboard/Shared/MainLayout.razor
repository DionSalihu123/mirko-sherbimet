@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="app-shell">
    <aside class="sidebar">
        <div class="brand-row">
            <div class="brand-icon" aria-hidden="true"></div>
            <div>
                <div class="brand">Gatekeeper</div>
                <div class="subtitle">Siguria e login-it me JWT</div>
            </div>
        </div>
        <nav>
            <a class="nav-link @Active("/")" href="/">Ballina</a>
            <a class="nav-link @Active("/login")" href="/login">Login</a>
            <a class="nav-link @Active("/api-test")" href="/api-test">Testimi i API-ve</a>
            <a class="nav-link @Active("/ai-model")" href="/ai-model">Modeli AI</a>
        </nav>
        <div class="sidebar-footer">
            <div class="status-dot online"></div>
            <span>Shërbimet po punojnë lokalisht</span>
            <small>Punuar nga Dion Salihu</small>
        </div>
    </aside>
    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private string Active(string path) =>
        Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/') == path.TrimStart('/')
        || (path == "/" && string.IsNullOrEmpty(Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/')))
            ? "active"
            : "";
}
