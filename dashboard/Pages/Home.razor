@page "/"
@using dashboard.Services
@inject SessionState Session

<section class="hero">
    <h1>Autentifikim JWT në mikroshërbime</h1>
    <p class="hero-text">
        Gatekeeper demonstron regjistrimin dhe login-in me bcrypt dhe JWT. Dy Resource API
        të pavarura validojnë të njëjtin token, ndërsa modeli Isolation Forest trajnohet mbi
        të dhëna login-i për të kuptuar sjellje të pazakonta.
    </p>
</section>

<div class="flow-strip">
    <div class="flow-step">
        <span class="flow-num">1</span>
        <span>Regjistrim / login</span>
    </div>
    <div class="flow-arrow">→</div>
    <div class="flow-step">
        <span class="flow-num">2</span>
        <span>Marrja e JWT token-it</span>
    </div>
    <div class="flow-arrow">→</div>
    <div class="flow-step">
        <span class="flow-num">3</span>
        <span>Thirrja e API-ve të mbrojtura</span>
    </div>
</div>

<h2 class="section-title">Çfarë demonstron sistemi</h2>

<div class="feature-grid">
    <a href="/login" class="feature-card">
        <div class="feature-icon icon-auth"></div>
        <h3>Autentifikimi</h3>
        <p>Krijon përdorues, ruan password-in si hash me bcrypt dhe lëshon JWT token me afat 30 minuta.</p>
        <span class="feature-link">Hap faqen e login-it</span>
    </a>
    <a href="/api-test" class="feature-card">
        <div class="feature-icon icon-api"></div>
        <h3>API të mbrojtura</h3>
        <p>Dy Resource Services përdorin sekretin e njëjtë JWT dhe refuzojnë kërkesat pa token valid.</p>
        <span class="feature-link">Hap testimin e API-ve</span>
    </a>
    <a href="/ai-model" class="feature-card">
        <div class="feature-icon icon-ai"></div>
        <h3>Detektimi i anomalive</h3>
        <p>Trajnon Isolation Forest mbi features të login-it si ora, IP e re, tentativa të dështuara dhe sinjale geo.</p>
        <span class="feature-link">Shiko statusin e modelit</span>
    </a>
    <div class="feature-card feature-card-static">
        <div class="feature-icon icon-arch"></div>
        <h3>Arkitekturë e shpërndarë</h3>
        <p>Auth Service, dy Resource API, moduli Python për AI dhe Dashboard-i punojnë si pjesë të ndara.</p>
    </div>
</div>

<div class="session-panel">
    <div class="session-header">
        <h4>Sesioni aktual</h4>
        @if (!string.IsNullOrEmpty(Session.JwtToken))
        {
            <span class="pill pill-ok">Aktiv</span>
        }
    </div>
    @if (!string.IsNullOrEmpty(Session.JwtToken))
    {
        <p class="session-ok">I kyçur si <strong>@Session.Email</strong></p>
        <div class="token-box">@(Session.JwtToken!.Length > 100 ? Session.JwtToken[..100] + "…" : Session.JwtToken)</div>
        <a href="/api-test" class="btn btn-primary btn-sm mt-3">Testo endpoint-et e mbrojtura</a>
    }
    else
    {
        <p class="session-empty">Nuk ka sesion aktiv. <a href="/login">Bëj login</a> për të marrë token.</p>
    }
</div>
