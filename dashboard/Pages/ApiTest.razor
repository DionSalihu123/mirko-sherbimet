@page "/api-test"
@using dashboard.Services
@inject IHttpClientFactory HttpClientFactory
@inject SessionState Session

<div class="page-header">
    <h1 class="page-title">API Explorer</h1>
    <p class="page-desc">Call secure endpoints on both resource services — with no token, a valid JWT, or an invalid one.</p>
</div>

@if (string.IsNullOrEmpty(Session.JwtToken))
{
    <div class="toast toast-warn">Please <a href="/login">sign in</a> first to get a JWT.</div>
}
else
{
    <p class="session-ok mb-4">Using token for <strong>@Session.Email</strong></p>
}

<div class="demo-grid">
    <button class="demo-btn demo-fail" @onclick="() => Call(1, DemoMode.NoToken)" disabled="@busy">
        <span class="demo-code">401</span>
        <span>Resource 1 — no token</span>
    </button>
    <button class="demo-btn demo-ok" @onclick="() => Call(1, DemoMode.ValidToken)" disabled="@busy">
        <span class="demo-code">200</span>
        <span>Resource 1 — valid JWT</span>
    </button>
    <button class="demo-btn demo-fail" @onclick="() => Call(2, DemoMode.NoToken)" disabled="@busy">
        <span class="demo-code">401</span>
        <span>Resource 2 — no token</span>
    </button>
    <button class="demo-btn demo-ok" @onclick="() => Call(2, DemoMode.ValidToken)" disabled="@busy">
        <span class="demo-code">200</span>
        <span>Resource 2 — valid JWT</span>
    </button>
    <button class="demo-btn demo-fail demo-wide" @onclick="() => Call(1, DemoMode.InvalidToken)" disabled="@busy">
        <span class="demo-code">401</span>
        <span>Invalid or tampered token</span>
    </button>
</div>

@if (results.Count > 0)
{
    <h4 class="mt-4 mb-3">Results</h4>
    @foreach (var r in results)
    {
        <div class="result-row @(r.Ok ? "result-ok" : "result-fail")">
            <span class="result-status">HTTP @r.Status</span>
            <strong>@r.Label</strong>
            <pre>@r.Body</pre>
        </div>
    }
}

@code {
    private enum DemoMode { NoToken, ValidToken, InvalidToken }

    private readonly List<TestResult> results = new();
    private bool busy;

    private async Task Call(int service, DemoMode mode)
    {
        busy = true;
        var label = mode switch
        {
            DemoMode.NoToken => $"resource-service-{service} /secure (no token)",
            DemoMode.ValidToken => $"resource-service-{service} /secure (valid JWT)",
            _ => $"resource-service-{service} /secure (invalid JWT)"
        };

        try
        {
            var client = HttpClientFactory.CreateClient($"resource{service}");
            var request = new HttpRequestMessage(HttpMethod.Get, "/secure");

            if (mode == DemoMode.ValidToken && !string.IsNullOrEmpty(Session.JwtToken))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.JwtToken);
            else if (mode == DemoMode.InvalidToken && !string.IsNullOrEmpty(Session.JwtToken))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.JwtToken + "invalid");

            var resp = await client.SendAsync(request);
            var body = await resp.Content.ReadAsStringAsync();
            results.Insert(0, new TestResult
            {
                Label = label,
                Status = (int)resp.StatusCode,
                Ok = resp.IsSuccessStatusCode,
                Body = body
            });
        }
        catch (Exception ex)
        {
            results.Insert(0, new TestResult { Label = label, Status = 0, Ok = false, Body = ex.Message });
        }
        busy = false;
    }

    private class TestResult
    {
        public string Label { get; set; } = "";
        public int Status { get; set; }
        public bool Ok { get; set; }
        public string Body { get; set; } = "";
    }
}
