@page "/ai-model"
@inject IWebHostEnvironment Env

<div class="page-header">
    <h1 class="page-title">Modeli AI</h1>
    <p class="page-desc">Isolation Forest trajnohet mbi sjellje të login-it për të dalluar raste të pazakonta si brute-force ose udhëtim i pamundur.</p>
</div>

<div class="stats-row">
    <div class="stat-chip">
        <span class="stat-label">Algoritmi</span>
        <span class="stat-value">Isolation Forest</span>
    </div>
    <div class="stat-chip">
        <span class="stat-label">Mostra trajnimi</span>
        <span class="stat-value">250+</span>
    </div>
    <div class="stat-chip">
        <span class="stat-label">Features</span>
        <span class="stat-value">10</span>
    </div>
</div>

<div class="panel">
    <h3>Trajnimi i modelit</h3>
    <p class="panel-intro">Këto komanda ekzekutohen nga folderi kryesor i projektit për ta trajnuar përsëri modelin.</p>
    <pre class="code-block">cd ~/mikro_sherbimet
python3 -m venv ai-service/.venv
ai-service/.venv/bin/pip install -r ai-service/requirements.txt
ai-service/.venv/bin/python ai-service/train.py</pre>
</div>

<div class="panel mt-3">
    <h3>Features hyrëse</h3>
    <div class="tag-cloud">
        <span>hour</span>
        <span>failed_attempts</span>
        <span>new_ip</span>
        <span>success_rate</span>
        <span>login_frequency</span>
        <span>country_changed</span>
        <span>impossible_travel</span>
        <span>distance_km</span>
        <span>hours_since_last_login</span>
        <span>user_agent_changed</span>
    </div>
</div>

<div class="panel mt-3">
    <h3>Skedarët e ruajtur</h3>
    <div class="file-status @(modelExists ? "file-ok" : "file-missing")">
        <span>models/isolation_forest.pkl</span>
        <strong>@(modelExists ? "Gati" : "Ekzekuto train.py")</strong>
    </div>
    <div class="file-status @(configExists ? "file-ok" : "file-missing")">
        <span>models/model_config.json</span>
        <strong>@(configExists ? "Gati" : "Mungon")</strong>
    </div>
</div>

@code {
    private bool modelExists;
    private bool configExists;

    protected override void OnInitialized()
    {
        var root = Path.GetFullPath(Path.Combine(Env.ContentRootPath, ".."));
        modelExists = File.Exists(Path.Combine(root, "models", "isolation_forest.pkl"));
        configExists = File.Exists(Path.Combine(root, "models", "model_config.json"));
    }
}
